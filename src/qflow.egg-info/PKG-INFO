    │   │   ├── POSCAR
    │   │   ├── CONTCAR       # 优化后结构
    │   │   └── .success
    │   ├── volume_1.0/       # 声子计算（平衡体积）
    │   │   ├── task.000000/
    │   │   ├── task.000001/
    │   │   ├── ...
    │   │   ├── task_perfect/ # 完美超胞（无位移）
    │   │   └── analyze/
    │   │       ├── phonopy_disp.yaml
    │   │       ├── phonopy_params.yaml
    │   │       ├── thermo_properties.yaml
